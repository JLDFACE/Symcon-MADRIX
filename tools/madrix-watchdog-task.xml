<?xml version="1.0" encoding="UTF-8"?>
<!--
  Import-Vorlage fuer die Windows-Aufgabenplanung.

  VOR dem Import anpassen:
    1. <UserId> ...\\AUTOLOGIN_USER ...  -> auf den automatisch angemeldeten Benutzer setzen
       (oder nach dem Import im Reiter "Allgemein" ueber "Benutzer/Gruppe aendern").
    2. Den Pfad im <Arguments> ggf. anpassen, falls das Skript woanders liegt.

  Import:  Aufgabenplanung > Aufgabe importieren... > diese Datei waehlen.
  Alternativ per Kommandozeile (als Administrator):
    schtasks /Create /TN "MADRIX Watchdog" /XML "C:\MadrixWatchdog\madrix-watchdog-task.xml"
-->
<Task version="1.3" xmlns="http://schemas.microsoft.com/windows/2004/02/mit/task">
  <RegistrationInfo>
    <Description>Startet MADRIX nach Absturz oder Freeze automatisch neu.</Description>
    <URI>\MADRIX Watchdog</URI>
  </RegistrationInfo>
  <Triggers>
    <LogonTrigger>
      <Enabled>true</Enabled>
    </LogonTrigger>
    <BootTrigger>
      <Enabled>true</Enabled>
    </BootTrigger>
  </Triggers>
  <Principals>
    <Principal id="Author">
      <UserId>AUTOLOGIN_USER</UserId>
      <LogonType>InteractiveToken</LogonType>
      <RunLevel>HighestAvailable</RunLevel>
    </Principal>
  </Principals>
  <Settings>
    <MultipleInstancesPolicy>IgnoreNew</MultipleInstancesPolicy>
    <DisallowStartIfOnBatteries>false</DisallowStartIfOnBatteries>
    <StopIfGoingOnBatteries>false</StopIfGoingOnBatteries>
    <AllowHardTerminate>true</AllowHardTerminate>
    <StartWhenAvailable>true</StartWhenAvailable>
    <RunOnlyIfNetworkAvailable>false</RunOnlyIfNetworkAvailable>
    <AllowStartOnDemand>true</AllowStartOnDemand>
    <Enabled>true</Enabled>
    <Hidden>false</Hidden>
    <ExecutionTimeLimit>PT0S</ExecutionTimeLimit>
    <RestartOnFailure>
      <Interval>PT1M</Interval>
      <Count>999</Count>
    </RestartOnFailure>
  </Settings>
  <Actions Context="Author">
    <Exec>
      <Command>powershell.exe</Command>
      <Arguments>-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File "C:\MadrixWatchdog\madrix-watchdog.ps1"</Arguments>
    </Exec>
  </Actions>
</Task>
